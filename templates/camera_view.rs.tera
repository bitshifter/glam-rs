#[inline]
#[must_use]
pub fn look_to_affine3(eye: {{ vec3 }}, dir: {{ vec3 }}, up: {{ vec3 }}) -> {{ affine3 }} {
    camera_impl::look_to_affine3::<{{ is_rh }}>(eye, dir, up)
}

