{% else %}
{# Z-up worlds: convert to Y-up, apply view, convert back #}

{% if is_rh %}
// Right-handed Z-up view functions
// Z-up to Y-up conversion: (x, y, z) -> (x, z, -y)
{% set Zu = "z" %}
{% set Zn = "y" %}
{% set sign = "-" %}
{% else %}
// Left-handed Z-up view functions
// Z-up to Y-up conversion: (x, y, z) -> (x, z, y)
{% set Zu = "z" %}
{% set Zn = "y" %}
{% set sign = "" %}
{% endif %}

#[inline]
#[must_use]
fn convert_zup_to_yup(v: {{ vec3 }}) -> {{ vec3 }} {
    {{ vec3 }}::new(v.x, v.{{ Zu }}, {{ sign }}v.{{ Zn }})
}

#[inline]
#[must_use]
fn convert_yup_to_zup_cols(m: {{ mat4 }}) -> {{ mat4 }} {
    // V_zup = V_yup * R_zup_to_yup
    // negate/swap columns of V_yup to account for zup->yup conversion
    let col0 = m.x_axis;
    let col1 = m.z_axis;
    let col2 = -m.y_axis;
    let col3 = m.w_axis;
    {{ mat4 }}::from_cols(col0, col1, col2, col3)
}

/// Creates a view matrix using a camera position, a focal point, and an up direction.
///
/// For a {{ handedness }}, {{ up_axis }} view coordinate system.
///
/// # Panics
///
/// Will panic if `up` is not normalized when `glam_assert` is enabled.
#[inline]
#[must_use]
pub fn look_at_mat4(eye: {{ vec3 }}, center: {{ vec3 }}, up: {{ vec3 }}) -> {{ mat4 }} {
    look_to_mat4(eye, (center - eye).normalize(), up)
}

/// Creates a view matrix using a camera position, a facing direction, and an up direction.
///
/// For a {{ handedness }}, {{ up_axis }} view coordinate system.
///
/// # Panics
///
/// Will panic if `dir` or `up` are not normalized when `glam_assert` is enabled.
#[inline]
#[must_use]
pub fn look_to_mat4(eye: {{ vec3 }}, dir: {{ vec3 }}, up: {{ vec3 }}) -> {{ mat4 }} {
    let eye_yup = convert_zup_to_yup(eye);
    let dir_yup = convert_zup_to_yup(dir);
    let up_yup = convert_zup_to_yup(up);
    let v_yup = camera_impl::look_to_mat4::<{{ is_rh }}>(eye_yup, dir_yup, up_yup);
    convert_yup_to_zup_cols(v_yup)
}

/// Creates a view transform using a camera position, a focal point, and an up direction.
///
/// For a {{ handedness }}, {{ up_axis }} view coordinate system.
///
/// # Panics
///
/// Will panic if `up` is not normalized when `glam_assert` is enabled.
#[inline]
#[must_use]
pub fn look_at_affine3(eye: {{ vec3 }}, center: {{ vec3 }}, up: {{ vec3 }}) -> {{ affine3 }} {
    look_to_affine3(eye, (center - eye).normalize(), up)
}

/// Creates a view transform using a camera position, a facing direction, and an up direction.
///
/// For a {{ handedness }}, {{ up_axis }} view coordinate system.
///
/// # Panics
///
/// Will panic if `dir` or `up` are not normalized when `glam_assert` is enabled.
#[inline]
#[must_use]
pub fn look_to_affine3(eye: {{ vec3 }}, dir: {{ vec3 }}, up: {{ vec3 }}) -> {{ affine3 }} {
    let eye_yup = convert_zup_to_yup(eye);
    let dir_yup = convert_zup_to_yup(dir);
    let up_yup = convert_zup_to_yup(up);
    let v_yup = look_to_affine3_internal(eye_yup, dir_yup, up_yup);
    {{ affine3 }} {
        matrix3: {{ mat3 }}::from_cols(v_yup.matrix3.x_axis, v_yup.matrix3.z_axis, -v_yup.matrix3.y_axis),
        translation: v_yup.translation,
    }
}

